---
const channel = import.meta.env.DOCS_CHANNEL || 'stable';
const base = '';
const channels = [
  { id: 'stable',  label: 'Stable' },
  { id: 'beta',    label: 'Beta' },
  { id: 'nightly', label: 'Nightly' },
];
---

<nav class="version-picker">
  <button type="button" class="version-trigger" aria-expanded="false" aria-haspopup="listbox">
    <span class="version-label">{channels.find(c => c.id === channel)?.label}</span>
    <svg class="chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2.5 3.75L5 6.25L7.5 3.75"/>
    </svg>
  </button>
  <ul class="version-menu" role="listbox">
    {channels.map((ch) => (
      <li role="option" aria-selected={ch.id === channel} data-value={`${base}/${ch.id}/`}>
        <span class="option-label">{ch.label}</span>
        {ch.id === channel && (
          <svg class="check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        )}
      </li>
    ))}
  </ul>
</nav>

<script>
  const trigger = document.querySelector('.version-trigger') as HTMLButtonElement;
  const menu = document.querySelector('.version-menu') as HTMLUListElement;

  function toggle(open?: boolean) {
    const next = open ?? trigger.getAttribute('aria-expanded') !== 'true';
    trigger.setAttribute('aria-expanded', String(next));
    menu.classList.toggle('open', next);
  }

  trigger?.addEventListener('click', () => toggle());

  menu?.querySelectorAll('li').forEach((li) => {
    li.addEventListener('click', () => {
      const href = li.dataset.value;
      if (href) window.location.href = href;
    });
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element)?.closest('.version-picker')) toggle(false);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') toggle(false);
  });
</script>

<style>
  .version-picker {
    position: relative;
  }

  .version-trigger {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    background: transparent;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    font-family: inherit;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    color: var(--sl-color-text);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .version-trigger:hover {
    border-color: var(--sl-color-text);
    background: var(--sl-color-gray-6);
  }

  .chevron {
    transition: transform 0.2s;
  }

  .version-trigger[aria-expanded='true'] .chevron {
    transform: rotate(180deg);
  }

  .version-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    min-width: 8rem;
    margin: 0;
    padding: 0.25rem;
    list-style: none;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s, transform 0.15s, visibility 0.15s;
    z-index: 100;
  }

  .version-menu.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .version-menu li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--sl-color-text);
    border-radius: 0.375rem;
    cursor: pointer;
    transition: background 0.1s;
  }

  .version-menu li:hover {
    background: var(--sl-color-gray-6);
  }

  .version-menu li[aria-selected='true'] {
    font-weight: 600;
  }

  .check {
    color: var(--sl-color-text-accent);
  }
</style>
