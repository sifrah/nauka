---
const channel = import.meta.env.DOCS_CHANNEL || 'stable';

// Detect if current build is a tag (e.g., v1.2.0) or a channel (stable/beta/nightly)
const isTag = channel.startsWith('v');
const displayLabel = isTag ? channel : channel.charAt(0).toUpperCase() + channel.slice(1);
---

<nav class="version-picker">
  <button type="button" class="version-trigger" aria-expanded="false" aria-haspopup="listbox">
    <span class="version-label">{displayLabel}</span>
    <svg class="chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2.5 3.75L5 6.25L7.5 3.75"/>
    </svg>
  </button>
  <div class="version-menu">
    <div class="version-menu-inner" id="version-menu-content">
      <div class="version-loading">Loading...</div>
    </div>
  </div>
</nav>

<script define:vars={{ channel }}>
  const picker = document.querySelector('.version-picker');
  const trigger = picker?.querySelector('.version-trigger');
  const menu = picker?.querySelector('.version-menu');
  const content = document.getElementById('version-menu-content');

  function toggle(open) {
    const next = open ?? trigger?.getAttribute('aria-expanded') !== 'true';
    trigger?.setAttribute('aria-expanded', String(next));
    menu?.classList.toggle('open', next);
  }

  trigger?.addEventListener('click', () => toggle());

  document.addEventListener('click', (e) => {
    if (!e.target?.closest('.version-picker')) toggle(false);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') toggle(false);
  });

  // Resolve the root URL (strip the channel/tag base path)
  const base = document.querySelector('link[rel="canonical"]')?.getAttribute('href') || '';
  const siteRoot = window.location.origin;

  // Fetch versions.json from site root
  fetch(`${siteRoot}/versions.json`)
    .then((r) => r.ok ? r.json() : null)
    .catch(() => null)
    .then((data) => {
      if (!content) return;

      const channels = ['stable', 'beta', 'nightly'];
      const versions = data?.versions || [];

      // Group by channel
      const grouped = {};
      channels.forEach((ch) => { grouped[ch] = []; });
      versions.forEach((v) => {
        if (grouped[v.channel]) grouped[v.channel].push(v);
      });

      // Check which tag paths actually exist (async, best-effort)
      const deployed = new Set();

      let html = '';
      channels.forEach((ch) => {
        const label = ch.charAt(0).toUpperCase() + ch.slice(1);
        const isCurrent = channel === ch;
        const tags = grouped[ch];

        html += `<div class="version-group-header">${label}</div>`;
        html += `<a class="version-item${isCurrent ? ' current' : ''}" href="/${ch}/">
          <span>latest${tags.length > 0 ? ' (' + tags[0].tag + ')' : ''}</span>
          ${isCurrent ? '<svg class="check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' : ''}
        </a>`;

        tags.forEach((v) => {
          const isCurrentTag = channel === v.tag;
          html += `<a class="version-item${isCurrentTag ? ' current' : ''}" href="/${v.tag}/">
            <span>${v.tag}</span>
            <span class="version-date">${v.date}</span>
          </a>`;
        });
      });

      content.innerHTML = html;
    });
</script>

<style>
  .version-picker {
    position: relative;
  }

  .version-trigger {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    background: transparent;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    font-family: inherit;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    color: var(--sl-color-text);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .version-trigger:hover {
    border-color: var(--sl-color-text);
    background: var(--sl-color-gray-6);
  }

  .chevron {
    transition: transform 0.2s;
  }

  .version-trigger[aria-expanded='true'] .chevron {
    transform: rotate(180deg);
  }

  .version-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    min-width: 12rem;
    margin: 0;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s, transform 0.15s, visibility 0.15s;
    z-index: 100;
  }

  .version-menu.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .version-menu-inner {
    max-height: 20rem;
    overflow-y: auto;
    padding: 0.25rem;
    scrollbar-width: thin;
  }

  .version-loading {
    padding: 0.75rem;
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    text-align: center;
  }
</style>

<style is:global>
  .version-group-header {
    padding: 0.5rem 0.75rem 0.2rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sl-color-gray-3);
    user-select: none;
  }

  .version-group-header:not(:first-child) {
    margin-top: 0.25rem;
    border-top: 1px solid var(--sl-color-gray-5);
    padding-top: 0.5rem;
  }

  .version-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    color: var(--sl-color-gray-2);
    border-radius: 0.375rem;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.1s, color 0.1s;
  }

  .version-item:hover {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-text);
  }

  .version-item.current {
    font-weight: 600;
    color: var(--sl-color-text);
  }

  .version-date {
    font-size: 0.7rem;
    color: var(--sl-color-gray-4);
  }

  .version-item .check {
    color: var(--sl-color-text-accent);
  }
</style>
