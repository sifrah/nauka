---
const channel = import.meta.env.DOCS_CHANNEL || 'stable';
const isTag = channel.startsWith('v');
const displayLabel = isTag ? channel : channel.charAt(0).toUpperCase() + channel.slice(1);
---

<nav class="version-picker" data-channel={channel}>
  <button type="button" class="version-trigger" aria-expanded="false">
    <span class="version-label">{displayLabel}</span>
    <svg class="chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2.5 3.75L5 6.25L7.5 3.75"/>
    </svg>
  </button>
  <div class="version-dropdown">
    <div class="version-dropdown-inner"></div>
  </div>
</nav>

<script>
  // Version picker — handles multiple instances on the page
  const siteRoot = window.location.origin;

  function initPicker(picker: Element) {
    const channel = picker.getAttribute('data-channel') || 'stable';
    const trigger = picker.querySelector('.version-trigger') as HTMLButtonElement;
    const dropdown = picker.querySelector('.version-dropdown') as HTMLElement;
    const inner = picker.querySelector('.version-dropdown-inner') as HTMLElement;

    if (!trigger || !dropdown || !inner) return;

    function toggle(open?: boolean) {
      const next = open ?? trigger.getAttribute('aria-expanded') !== 'true';
      trigger.setAttribute('aria-expanded', String(next));
      dropdown.classList.toggle('open', next);
    }

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      toggle();
    });

    document.addEventListener('click', (e) => {
      if (!(e.target as Element)?.closest('.version-picker')) toggle(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') toggle(false);
    });

    // Fetch and render versions
    fetch(`${siteRoot}/versions.json`)
      .then((r) => r.ok ? r.json() : null)
      .catch(() => null)
      .then((data) => {
        const channels = ['stable', 'beta', 'nightly'];
        const versions = data?.versions || [];

        const grouped: Record<string, Array<{tag: string, date: string}>> = {};
        channels.forEach((ch) => { grouped[ch] = []; });
        versions.forEach((v: {tag: string, channel: string, date: string}) => {
          if (grouped[v.channel]) grouped[v.channel].push(v);
        });

        let html = '';
        channels.forEach((ch) => {
          const label = ch.charAt(0).toUpperCase() + ch.slice(1);
          const isCurrent = channel === ch;
          const tags = grouped[ch];

          html += `<div class="vp-group-header">${label}</div>`;
          html += `<a class="vp-item${isCurrent ? ' vp-current' : ''}" href="/${ch}/">
            latest${tags.length > 0 ? ' (' + tags[0].tag + ')' : ''}
          </a>`;

          tags.forEach((v) => {
            const isCurrentTag = channel === v.tag;
            html += `<a class="vp-item${isCurrentTag ? ' vp-current' : ''}" href="/${v.tag}/">
              <span>${v.tag}</span>
              <span class="vp-date">${v.date}</span>
            </a>`;
          });
        });

        inner.innerHTML = html;
      });
  }

  document.querySelectorAll('.version-picker').forEach(initPicker);
</script>

<style>
  .version-picker {
    position: relative;
  }

  .version-trigger {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    background: transparent;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    font-family: inherit;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    color: var(--sl-color-text);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .version-trigger:hover {
    border-color: var(--sl-color-text);
    background: var(--sl-color-gray-6);
  }

  .chevron {
    transition: transform 0.2s;
  }

  .version-trigger[aria-expanded='true'] .chevron {
    transform: rotate(180deg);
  }

  .version-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    min-width: 14rem;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s, transform 0.15s, visibility 0.15s;
    z-index: 100;
  }

  .version-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .version-dropdown-inner {
    max-height: 20rem;
    overflow-y: auto;
    padding: 0.25rem;
    scrollbar-width: thin;
  }
</style>

<style is:global>
  .vp-group-header {
    padding: 0.5rem 0.75rem 0.2rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sl-color-gray-3);
    user-select: none;
  }

  .vp-group-header:not(:first-child) {
    margin-top: 0.25rem;
    border-top: 1px solid var(--sl-color-gray-5);
    padding-top: 0.5rem;
  }

  .vp-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    color: var(--sl-color-gray-2);
    border-radius: 0.375rem;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.1s, color 0.1s;
  }

  .vp-item:hover {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-text);
  }

  .vp-item.vp-current {
    font-weight: 600;
    color: var(--sl-color-text);
  }

  .vp-date {
    font-size: 0.7rem;
    color: var(--sl-color-gray-4);
  }
</style>
